# ── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# Public base URL of the app (used in email links). e.g. https://app.cloudleak.io
NEXT_PUBLIC_APP_URL=https://app.cloudleak.io

# ── AWS scanning ─────────────────────────────────────────────────────────────
CLOUDLEAK_AWS_ACCOUNT_ID=000000000000
AWS_REGION=us-east-1
CLOUDLEAK_SCAN_REGIONS=us-east-1     # comma-separated regions to scan
# Set to 1 ONLY for local dev/demos to use the fake inventory client (no real AWS
# account needed). Leave 0/unset in production so scans hit real AWS via the
# customer's connected cross-account IAM role.
CLOUDLEAK_FAKE_AWS=0

# ── Transactional email (Resend) ─────────────────────────────────────────────
# Without RESEND_API_KEY, invite/digest emails are logged instead of sent.
RESEND_API_KEY=
RESEND_FROM=CloudLeak <noreply@cloudleak.io>

# ── Billing (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_GROWTH=                 # Stripe Price ID for the Growth plan
STRIPE_PRICE_AGENCY=                 # Stripe Price ID for the Agency plan

# ── Scheduled scan worker (cron) ─────────────────────────────────────────────
# Shared secret required by the /api/worker/run cron endpoint.
CRON_SECRET=

# ── Integration tests only (a seeded auth user + that user's access token) ───
TEST_USER_ID=
TEST_USER_JWT=
